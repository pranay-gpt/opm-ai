# opm-ai environment variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git — it is in .gitignore

# ── LLM API Keys ───────────────────────────────────────────────────────────
# Groq (recommended — fast, free tier available): https://console.groq.com
GROQ_API_KEY=

# Tavily web search (used by explainer for citations): https://tavily.com
TAVILY_API=

# NVIDIA NIM (optional, for GPU-accelerated inference): https://build.nvidia.com
NVIDIA_NIM_API=

# ── OPM Binaries ───────────────────────────────────────────────────────────
# These paths are correct for Ubuntu with OPM PPA installed
OPM_FLOW_BINARY=/usr/bin/flow
RESINSIGHT_EXECUTABLE=/usr/bin/ResInsight
