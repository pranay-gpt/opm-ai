-- =============================================================================
-- {{ desc.title }}
-- Generated by opm-ai  |  https://github.com/pranay-gpt/opm-ai
-- Fluid system : {{ desc.fluid_system.value }}
-- Grid         : {{ desc.nx }} x {{ desc.ny }} x {{ desc.nz }}
-- Wells        : {{ desc.wells | length }}
-- =============================================================================

RUNSPEC

TITLE
  {{ desc.title }}

DIMENS
  {{ desc.nx }}  {{ desc.ny }}  {{ desc.nz }} /

OIL
WATER
{% if desc.fluid_system in [FluidSystem.BLACK_OIL, FluidSystem.GAS_WATER, FluidSystem.DRY_GAS] %}
GAS
{% endif %}

METRIC

WELLDIMS
  {{ [desc.wells | length, 2] | max }}  10  1  {{ [desc.wells | length, 2] | max }} /

START
  1 'JAN' 2025 /

UNIFIN
UNIFOUT

-- =============================================================================
GRID
-- =============================================================================

INITFILES

DX
  {{ desc.nx * desc.ny * desc.nz }}*{{ desc.dx }} /

DY
  {{ desc.nx * desc.ny * desc.nz }}*{{ desc.dy }} /

DZ
{% for layer in range(desc.nz) %}
  {{ desc.nx * desc.ny }}*{{ desc.dz }}{% if not loop.last %}
{% endif %}
{% endfor %}
/

TOPS
  {{ desc.nx * desc.ny }}*{{ desc.depth_top }} /

PORO
  {{ desc.nx * desc.ny * desc.nz }}*{{ "%.4f" | format(desc.porosity) }} /

PERMX
  {{ desc.nx * desc.ny * desc.nz }}*{{ "%.2f" | format(desc.permeability) }} /

PERMY
  {{ desc.nx * desc.ny * desc.nz }}*{{ "%.2f" | format(desc.permeability) }} /

PERMZ
  {{ desc.nx * desc.ny * desc.nz }}*{{ "%.4f" | format(desc.permeability * desc.perm_v_h_ratio) }} /

-- =============================================================================
PROPS
-- =============================================================================

PVTW
--  P_REF     BW       COMP         VISC   VISCOSIBILITY
  {{ "%.1f" | format(desc.p_init) }}  {{ "%.4f" | format(desc.water_fvf) }}  {{ "%.2e" | format(desc.water_comp) }}  {{ "%.4f" | format(desc.water_visc) }}  0 /

{% if desc.fluid_system == FluidSystem.OIL_WATER %}
PVCDO
--  P_REF     BO         COMP      VISC    VISCOSIBILITY
  {{ "%.1f" | format(desc.p_init) }}  {{ "%.4f" | format(desc.oil_fvf) }}  0.0  {{ "%.4f" | format(desc.oil_visc) }}  0 /
{% endif %}

{% if desc.fluid_system == FluidSystem.BLACK_OIL %}
PVTO
--   Rs    P       Bo       Visc
   0   {{ "%.1f" | format(desc.p_init * 0.1) }}  {{ "%.4f" | format(desc.oil_fvf * 0.8) }}  {{ "%.4f" | format(desc.oil_visc * 1.5) }}
        {{ "%.1f" | format(desc.p_init * 0.5) }}  {{ "%.4f" | format(desc.oil_fvf * 0.9) }}  {{ "%.4f" | format(desc.oil_visc * 1.2) }}
        {{ "%.1f" | format(desc.p_init) }}       {{ "%.4f" | format(desc.oil_fvf) }}         {{ "%.4f" | format(desc.oil_visc) }}
/
/

PVDG
--   P        Bg       Visc
  {{ "%.1f" | format(desc.p_init * 0.1) }}  {{ "%.5f" | format(desc.gas_fvf * 5) }}  {{ "%.4f" | format(desc.gas_visc * 3) }}
  {{ "%.1f" | format(desc.p_init * 0.5) }}  {{ "%.5f" | format(desc.gas_fvf * 2) }}  {{ "%.4f" | format(desc.gas_visc * 1.5) }}
  {{ "%.1f" | format(desc.p_init) }}       {{ "%.5f" | format(desc.gas_fvf) }}       {{ "%.4f" | format(desc.gas_visc) }}
/
{% endif %}

DENSITY
--  OIL    WATER   GAS
  800.0  1025.0  1.0 /

ROCK
--  P_REF   COMPRESS
  {{ "%.1f" | format(desc.p_init) }}  4.84E-5 /

SWOF
-- Sw      Krw       Krow    Pcow
   {{ "%.3f" | format(desc.swi) }}  0.00000  1.00000  0.0
   {{ "%.3f" | format(desc.swi + 0.2) }}  0.00200  0.50000  0.0
   {{ "%.3f" | format(desc.swi + 0.4) }}  0.02000  0.15000  0.0
   {{ "%.3f" | format(desc.swi + 0.6) }}  0.10000  0.03000  0.0
   {{ "%.3f" | format([desc.swi + 0.8, 1.0] | min) }}  0.40000  0.00000  0.0
   1.000  1.00000  0.00000  0.0
/

-- =============================================================================
SOLUTION
-- =============================================================================

EQUIL
--  DATUM  P_DATUM  OWC    Pc_OWC  GOC   Pc_GOC
  {{ "%.1f" | format(desc.depth_top + (desc.nz * desc.dz) / 2) }}  {{ "%.1f" | format(desc.p_init) }}  {{ "%.1f" | format(desc.depth_top + desc.nz * desc.dz + 100) }}  0  0  0 /

RPTSOL
  'SWAT'  'PRESSURE' /

-- =============================================================================
SUMMARY
-- =============================================================================

FOPR
FWPR
FWCT
FBHP
FWIR
FOPT
FWPT

{% for w in desc.wells %}
WOPR
  '{{ w.name }}' /
/
WBHP
  '{{ w.name }}' /
/
{% endfor %}

-- =============================================================================
SCHEDULE
-- =============================================================================

RPTSCHED
  'PRES'  'SWAT' /

{% if desc.wells %}
WELSPECS
{% for w in desc.wells %}
  '{{ w.name }}'  '{{ w.group }}'  {{ w.i }}  {{ w.j }}  1*  {% if w.type == 'INJECTOR' %}'WATER'{% else %}'OIL'{% endif %} /
{% endfor %}
/

COMPDAT
{% for w in desc.wells %}
  '{{ w.name }}'  {{ w.i }}  {{ w.j }}  {{ w.k1 }}  {{ w.k2 }}  'OPEN'  1*  1*  0.15 /
{% endfor %}
/

{% for w in desc.wells if w.type == 'PRODUCER' %}
WCONPROD
  '{{ w.name }}'  'OPEN'  '{{ w.control }}'  {{ "%.1f" | format(w.rate) }}  1*  1*  1*  1*  {{ "%.1f" | format(w.bhp_limit) }} /
/
{% endfor %}

{% for w in desc.wells if w.type == 'INJECTOR' %}
WCONINJE
  '{{ w.name }}'  '{{ w.inj_fluid }}'  'OPEN'  'RATE'  {{ "%.1f" | format(w.inj_rate) }}  1*  {{ "%.1f" | format(w.inj_bhp_max) }} /
/
{% endfor %}
{% endif %}

TSTEP
{% if desc.report_freq == 'monthly' %}
  {{ (desc.sim_years * 12) | int }}*30 /
{% elif desc.report_freq == 'quarterly' %}
  {{ (desc.sim_years * 4) | int }}*91 /
{% else %}
  {{ desc.sim_years | int }}*365 /
{% endif %}

END
